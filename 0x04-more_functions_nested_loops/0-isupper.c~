#include "main.h"

/**
 * main - run codes
 * _isupper - checks for uppercase letter
 * @c: entry of character
 * Return: 1 (is theres a upper case letter)
 */

int _isupper(int c)
{
	int c;
	int i;

	for (i = 65; i < 98; i++)
	{
		if (c == i)
		{
			putchar(c);
			return (1);
		}
		putchar(c);
		return (0);
	}
}
