#include "main.h"
#include <stdio.h>
#include <string.h>

/**
 * puts_half - print half of a string
 * @str: string para,meter
 */

void puts_half(char *str)
{
	int i, lengt, halfl;

	lengt = strlen(str);

	if(lengt % 2 == 0)
	{
		halfl = lengt / 2;
		for (i = halfl; i <= halfl; i++)
		{
			putchar(str[i]);
		}
	} else
	{
		halfl = (lengt - 1) / 2;
		for (i = halfl; i <= halfl; i++)
		{
			putchar(str[i]);
		}
	}
	putchar('\n');
}
